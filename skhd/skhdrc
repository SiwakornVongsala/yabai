# Focus windows with option + h/j/k/l.
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Move windows with shift + option + h/j/k/l.
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east
ctrl + alt - return : "$HOME/.config/yabai/swap-largest-window.sh"

# Cycle focus and return to the most recently focused window.
# alt - n : yabai -m window --focus next
# alt - p : yabai -m window --focus prev
# alt - b : yabai -m window --focus recent

# Change layout for the current window or space.
# alt - f : yabai -m window --toggle zoom-fullscreen
alt - z : yabai -m window --toggle zoom-parent
ctrl + alt - s : yabai -m window --toggle split
alt - r : yabai -m space --rotate 90
alt - t : yabai -m window --toggle float
alt - e : yabai -m space --balance
shift + alt - t : "$HOME/.config/yabai/float-large-space.sh"
shift + ctrl + alt - t : "$HOME/.config/yabai/float-large-space.sh" xlarge
shift + alt - 0 : "$HOME/.config/yabai/float-large-space.sh" full
shift + alt - m : "$HOME/.config/yabai/dev-mobile-layout.sh"
shift + alt - space : yabai -m space --layout float
shift + alt - b : yabai -m space --layout bsp
shift + alt - x : yabai -m space --mirror x-axis
shift + alt - y : yabai -m space --mirror y-axis
# alt - g : yabai -m space --toggle gap
# shift + alt - g : yabai -m space --toggle padding

# Move a window between adjacent Spaces and follow it.
# shift + alt - left  : yabai -m window --space prev --focus
# shift + alt - right : yabai -m window --space next --focus

# Focus Spaces by number.
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# Focus common Spaces.
alt - a : yabai -m space --focus 1
alt - s : yabai -m space --focus 2
alt - d : yabai -m space --focus 3
alt - f : yabai -m space --focus 4
alt - g : yabai -m space --focus 5

# Move a window to a numbered Space and follow it.
shift + alt - 1 : yabai -m window --space 1 --focus
shift + alt - 2 : yabai -m window --space 2 --focus
shift + alt - 3 : yabai -m window --space 3 --focus
shift + alt - 4 : yabai -m window --space 4 --focus
shift + alt - 5 : yabai -m window --space 5 --focus
shift + alt - 6 : yabai -m window --space 6 --focus
shift + alt - 7 : yabai -m window --space 7 --focus
shift + alt - 8 : yabai -m window --space 8 --focus
shift + alt - 9 : yabai -m window --space 9 --focus

# Move a window to a common Space and follow it.
shift + alt - a : yabai -m window --space 1 --focus
shift + alt - s : yabai -m window --space 2 --focus
shift + alt - d : yabai -m window --space 3 --focus
shift + alt - f : yabai -m window --space 4 --focus

# Focus a display, or send a window to it and follow focus.
ctrl + alt - h : yabai -m display --focus west
ctrl + alt - l : yabai -m display --focus east
shift + ctrl + alt - h : yabai -m window --display west --focus
shift + ctrl + alt - l : yabai -m window --display east --focus

# Resize the focused tile by adjusting its split ratio.
ctrl + alt - left  : yabai -m window --ratio rel:-0.05
ctrl + alt - right : yabai -m window --ratio rel:0.05
